# ─── TrapForge — .gitignore ───────────────────────────────────

# ── SECURITY — NEVER COMMIT THESE ────────────────────────────
.env
*.env
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets.json
credentials.json

# ── PYTHON ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
*.pyc
*.pyo

# ── VIRTUAL ENVIRONMENTS ─────────────────────────────────────
venv/
env/
ENV/
.venv/
.env/
virtualenv/

# ── NODE / REACT / VITE ──────────────────────────────────────
node_modules/
dist/
.vite/
*.local

# ── LOGS ─────────────────────────────────────────────────────
*.log
logs/
log_files/
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS FILES ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ── IDE / EDITORS ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── TESTING ──────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# ── MISC ─────────────────────────────────────────────────────
*.zip
*.tar.gz
*.bak
*.tmp
.cache/
